{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mini AI 1C",
  "version": "1.2.10",
  "identifier": "com.mini-ai-1c",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1440",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mini AI 1C Agent",
        "width": 400,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "template": "wix/main.wxs"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "mcp-servers/*"
    ]
  }
}
